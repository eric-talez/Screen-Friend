{
  "name": "@ai-3d-demo/desktop",
  "private": true,
  "version": "0.1.0",
  "description": "Electron desktop shell for the Screen Friend companion (Slice 2).",
  "main": "dist/main.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "compile": "tsc",
    "start": "tsc && electron .",
    "dev": "tsc && VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "dev:interactive": "tsc && VITE_DEV_SERVER_URL=http://localhost:5173 SCREEN_FRIEND_INTERACTIVE=1 electron ."
  },
  "devDependencies": {
    "electron": "^36.0.0",
    "typescript": "^5.7.3"
  }
}
